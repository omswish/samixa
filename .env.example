# Nutanix Config
NUTANIX_USER=your_nutanix_username
NUTANIX_PASS=your_nutanix_password
NUTANIX_HOST=your_nutanix_host
NUTANIX_PORT=9440

# SolarWinds Config
SW_HOST_SERVERS=your_solarwinds_servers_host
SW_SERVERS_USER=your_solarwinds_servers_username
SW_SERVERS_PASS=your_solarwinds_servers_password
SW_HOST_NETWORKS=your_solarwinds_networks_host
SW_NETWORKS_USER=your_solarwinds_networks_username
SW_NETWORKS_PASS=your_solarwinds_networks_password

# Symphony Summit Config (AD authentication)
SYM_USER=your_symphony_username
SYM_PASS=your_symphony_password
SYM_URL=your_symphony_dashboard_url

# Runtime root for SQLite DB, sessions, logs, and local collector settings
ITDASH_RUNTIME_ROOT=C:\ProgramData\UAIL\ITDashboard

# Local encrypted secret store passphrase
SECRET_STORE_PASSPHRASE=replace_with_long_random_secret

# Optional Postgres mirror
# POSTGRES_URL=postgresql://itdash_user:change_me@localhost:5432/itdash
# POSTGRES_SSL=false

# Dashboard auth (shared by Next.js and frontdoor proxy)
APP_AUTH_SECRET=replace_with_long_random_secret
APP_ADMIN_PASSWORD=17172737
APP_OPERATOR_PASSWORD=17172737
APP_LOGIN_PASSWORD=17172737
VIEWER_SESSION_DAYS=365
ADMIN_SESSION_HOURS=12
OPERATOR_FRONTDOOR_PORT=21060
ADMIN_FRONTDOOR_PORT=21061
